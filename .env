TEATROAPP_EXPORT_SOURCES=bol,ticketline,imperdivel
TEATROAPP_AUTORUN=1
TEATROAPP_AUTORUN_BLOCKING=1
TEATROAPP_PIECES_LIST_URL=https://teatro.app/manager/plays
TEATROAPP_PIECES_STATUS=
TEATROAPP_SLOW_MO_MS=200

