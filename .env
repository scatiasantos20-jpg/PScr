# ─────────────────────────────────────────────────────────────────────────────
# Selecção de scrapers (corre sempre a partir do .env)
#bol,ticketline,imperdivel
# SCRAPERS=bol,ticketline,imperdivel,teatrovariedades
# SCRAPERS=all

# ─────────────────────────────────────────────────────────────────────────────
SCRAPERS=bol


# Ticketline (meses a correr)
TICKETLINE_YEAR=2026
TICKETLINE_MONTH=3
TICKETLINE_PAGES=1-2
TICKETLINE_CATEGORY_IDS=102,143,305
TICKETLINE_DISCOVER=0
# quantos sub-eventos (dentro de um multi) processar | Para  processar todos TICKETLINE_MULTI_LIMIT=0
TICKETLINE_MULTI_LIMIT=1
TICKETLINE_EVENTS_PER_PAGE=1-2
TICKETLINE_EVENTS_OFFSET_PER_PAGE=0

# ─────────────────────────────────────────────────────────────────────────────
# Limites de extracção (um range global para todos)
# Formato: inicio-fim (ex.: 10-20) => range(10, 20)
# ─────────────────────────────────────────────────────────────────────────────
GLOBAL_EVENT_RANGE=20-21

# Cache
CACHE_TTL_DAYS=180
CACHE_DIR=C:\Users\catia\Desktop\Work\Peças_WebScraper\.cache

# Delay (global, para todos)
REQUEST_DELAY_MIN=60
REQUEST_DELAY_MAX=120
SLOW_MO_MS=80
DELAY_MIN=0.6
DELAY_MAX=1.4

# ─────────────────────────────────────────────────────────────────────────────
# Directórios
# ─────────────────────────────────────────────────────────────────────────────
BASE_DIRECTORY=C:\Users\catia\Desktop\TPT\EmCena
POSTERS_SUBDIR=Cartazes

# ─────────────────────────────────────────────────────────────────────────────
# Delays/Timeouts
# ─────────────────────────────────────────────────────────────────────────────
REQUEST_DELAY_MIN=120
REQUEST_DELAY_MAX=160

URLLIB_TIMEOUT=15
REQUESTS_TIMEOUT=30
IMAGE_TIMEOUT=30

# ─────────────────────────────────────────────────────────────────────────────
# User-Agent (preferível 1 UA fixo; lista/ficheiro só se for estritamente necessário)
# ─────────────────────────────────────────────────────────────────────────────
USER_AGENTS_FILE=C:\Users\catia\Desktop\Work\Peças_WebScraper\scrapers\user_agents.txt
# ─────────────────────────────────────────────────────────────
# BASE
# ─────────────────────────────────────────────────────────────
