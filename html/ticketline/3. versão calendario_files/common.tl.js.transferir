
if (!Function.prototype.bind ) {
    Function.prototype.bind = function( obj ) {
        var slice = [].slice,
                args = slice.call(arguments, 1), 
                self = this, 
                nop = function () {}, 
                bound = function () {
                    return self.apply( this instanceof nop ? this : ( obj || {} ), 
                                                            args.concat( slice.call(arguments) ) );
                };

        nop.prototype = self.prototype;

        bound.prototype = new nop();

        return bound;
    };
}

if (!String.prototype.reverse) {
    String.prototype.reverse=function(){return this.split("").reverse().join("");}
}
if (!String.prototype.trim) {
    String.prototype.trim = function() { return this.replace(/^\s+|\s+$/g,'');}
}

if (!Array.prototype.indexOf) {
    Array.prototype.indexOf = function(elt /*, from*/)
    {
        var len = this.length;

        var from = Number(arguments[1]) || 0;
        from = (from < 0)
             ? Math.ceil(from)
             : Math.floor(from);
        if (from < 0)
          from += len;

        for (; from < len; from++)
        {
          if (from in this &&
              this[from] === elt)
            return from;
        }
        return -1;
    };
}

if (!window.console) 
    window.console = {
        log:    function() {}, 
        error:  function() {}, 
        trace:  function() {}, 
        warn:   function() {}
    };

var TL = (function(){
    var TL = {}, matchMedia = window.matchMedia || window.msMatchMedia, height, lock = false;

    if (!matchMedia) { // failover
        $.ajax({
          url: '/static/js/respond.min.js',
          dataType: "script",
          async: false,
          cache: true,
          success: function(){matchMedia = window.matchMedia;}
        });
    };

    TL.getTemplate = function(template) {
        var data = $('script[type="html/template"][data-template="' + template + '"]').html();
        if (typeof data == 'undefined') return;
        return data.trim();
    };

    TL.getJsonData = function(data) {
        var jsonData,jsonString = $('script[type="text/json"][data-name="' + data + '"]').html();
        if (typeof jsonString == 'undefined') return;
        jsonString = jsonString.trim();
        try {
            jsonData = jQuery.parseJSON(jsonString);
        } catch (e) {
            jsonData = eval(jsonString);
        }
        return jsonData;
    };

    TL.renderTemplate = function(template, obj) {
        for (var property in obj) {
            if (obj[property] == null) obj[property] = "";  
            template = template.replace('#' + property +'#', obj[property]);
        }
        return template;
    };

    TL.replaceDOM = function(dom, obj) {
        for (var property in obj) {
            dom.find('[data-element="' + property + '"]').html(obj[property]);
            dom.find('[data-element="' + property + '"]').attr('data-value', property);
        }
    };

    TL.onResize = function() {
        var _height = $('html body .wrapper').height(); //$('html').height();
        if (TL.environment.isIframe() && (!height || height != _height && !lock)) {
            lock = true; height = _height;
            TL.messageCentral.postMessage('{"action": "setHeight", "height": ' + height + '}', '*', window.parent);
            setTimeout(function() { lock = false; }, 250);
        }
    }

    TL.lazyLoadHtml = function(el, callback) {
        var $el = $(el); // cast jquery element
        if ($el.length == 0 || $el.hasClass('loading')) return;
        try {
            if ($el.attr('data-media') && matchMedia && typeof document.documentElement.style.opacity!=='undefined') {
                if (!matchMedia($el.attr('data-media')).matches) return; 
            }
        } catch (e) {}
        $el.addClass('loading');
        if (typeof callback == 'undefined' && $el.attr('data-callback') && typeof window[$el.attr('data-callback')] == 'function') {
            callback = window[$el.attr('data-callback')];
        }
        $.ajax({
                type: "GET",
                async: true,
                cache: true,
                url: $el.attr('data-src'),
                success: function(data) {
                    $el.html(data);
                    $el.removeClass('loading');
                    if (typeof callback === 'function') {
                        callback.apply();
                    }
                    try {
                        if ('attachEvent' in document) {
                            SAPO.Mobile.SDKCommunication.findPubArea();
                        }
                        if (typeof TL.loadImg === 'function') {
                            TL.loadImg();
                        }
                    } catch (e) {}
                },
                dataType: 'html'
        });
    };

    TL.messageCentral = function(){
        var interval_id,
            last_hash,
            cache_bust = 1,
            attached_callback,
            window = this;

        return {
            postMessage : function(message, target_url, target) {
                //console.info("Sending .....", message, target_url, target);
                if (!target_url) {
                    return;
                }
                target = target || parent;  // default to parent
                if (window['postMessage']) {
                    target['postMessage'](message, target_url.replace( /([^:]+:\/\/[^\/]+).*/, '$1'));
                } else if (target_url) {
                    target.location = target_url.replace(/#.*$/, '') + '#' + (+new Date) + (cache_bust++) + '&' + message;
                }
            },

            receiveMessage : function(callback, source_origin) {
                if (window['postMessage']) {
                    // bind the callback to the actual event associated with window.postMessage
                    if (callback) {
                        attached_callback = function(e) {
                            if ((typeof source_origin === 'string' && e.origin !== source_origin)
                                || (Object.prototype.toString.call(source_origin) === "[object Function]" && source_origin(e.origin) === !1)) {
                                return !1;
                            }
                            callback(e);
                        };
                    }
                    if (window['addEventListener']) {
                        window[callback ? 'addEventListener' : 'removeEventListener']('message', attached_callback, !1);
                    } else {
                        window[callback ? 'attachEvent' : 'detachEvent']('onmessage', attached_callback);
                    }
                } else {
                    interval_id && clearInterval(interval_id);
                    interval_id = null;

                    if (callback) {
                        interval_id = setInterval(function(){
                            var hash = document.location.hash,
                                re = /^#?\d+&/;
                            if (hash !== last_hash && re.test(hash)) {
                                last_hash = hash;
                                callback({data: hash.replace(re, '')});
                            }
                        }, 100);
                    }
                }
            }
        };
    }();

    $(document).ready(function(){
        var findAndLoadLazyHtml = function() {
            $('div[data-element="lazy-html"]').each(function(){
                if ($(this).html().trim().length == 0) { // only load if dont have content
                    TL.lazyLoadHtml(this);
                }
            });
        };
        //$(document).bind('orientationchange.lazy', findAndLoadLazyHtml);
        $(window).bind('resize.lazy', findAndLoadLazyHtml);
        findAndLoadLazyHtml.apply(null,[]);
        //height = $('html').height();
        if (TL.environment.isIframe()) {
            if (navigator.userAgent.indexOf('Safari') != -1 && navigator.userAgent.indexOf('Chrome') == -1
                && document.cookie.indexOf("safari_cookie_fix") < 0) {
                TL.messageCentral.postMessage('{"action":"safariCookieFix"}', "*", window.parent);
            }
            TL.onResize();
            setInterval(function () {
                if ($('html body .wrapper').height() != height) { TL.onResize(); }
            }, 250);

            $(window).bind('resize', function() { TL.onResize(); });
        }

    });

    return TL;
})();

(function(scope){
    var is3dSupport             = (typeof document.documentElement.style.WebkitPerspective !== 'undefined');
    var isNativeScrollSupport   = window.getComputedStyle && ('WebkitOverflowScrolling' in window.getComputedStyle(document.createElement('div')));
    var isTransform3dSupport    = window.getComputedStyle && 
                                        (('webkitTransform' in window.getComputedStyle(document.createElement('div')))
                                    ||  ('OTransform' in window.getComputedStyle(document.createElement('div')))
                                    ||  ('msTransform' in window.getComputedStyle(document.createElement('div')))
                                    ||  ('MozTransform' in window.getComputedStyle(document.createElement('div')))
                                    ||  ('transform' in window.getComputedStyle(document.createElement('div'))));
    var isTouchSupport          = !!(('ontouchstart' in window) || window.DocumentTouch && document instanceof DocumentTouch);
    var isMobileResolution      = matchMedia("only screen and (min-width:640px)").matches;

    var $rootElement            = $(document).children();
    var environment = (function(){
        var type = {
            pointer:    !isTouchSupport,
            touch:      isTouchSupport
        };
        var mode = {
            mobile:     !isMobileResolution,
            desktop:    isMobileResolution
        };
        var screenSize = {
            small:          matchMedia("only screen and (max-width:640px)").matches,
            medium:         matchMedia("only screen and (max-width:1023px)").matches,
            large:          matchMedia("only screen and (min-width:1024px)").matches,
            extra_large:    null
        }
        if (!screenSize.small && !screenSize.medium && !screenSize.large) { //fail all tests, fallback
            screenSize = {
                small:          window.screen.width <= 640,
                medium:         window.screen.width <= 1023,
                large:          window.screen.width >= 1024,
                extra_large:    null
            }
        }
        var language = __ENV__.language || 'pt';

        $rootElement.addClass(type.touch ? 'touch' : 'no-touch'); // add to html so css loaded for especific environment

        // set server information about client if plataform empty
        $(document).ready(function(){
            if (__ENV__.platform.trim().length == 0) {
                var userInterface = type.pointer ? 'pointer' : 'touch';
                var mediaSize = screenSize.large ? 'large' : (screenSize.medium ? 'medium' : 'small');
                scope.Service.setEnvoriment(userInterface, mediaSize);
            }
            var mediaSize = screenSize.large ? 'large' : (screenSize.medium ? 'medium' : 'small');
        });

        // notify server if exists campaign via hash url
        $(document).ready(function() {
            var campaign = window.location.hash.match(/(?:\?|\&)?utm_campaign=([^\&]*)/);
            if (campaign !== null && campaign.length > 0) {
                var term = window.location.hash.match(/(?:\?|\&)?utm_term=([^\&]*)/);
                scope.Service.setCampaign(campaign[1], term !== null && term.length > 0 ? term[1] : '');
            }
        });

        return {
            getType:        function () { return type; },
            getMode:        function () { return mode; },
            getLanguage:    function () { return language; },
            getSreenSize:   function () { return screenSize; },
            isIframe:       function () { return self!==top; },
            test: {
                touch:              isTouchSupport,
                mobileResolution:   isMobileResolution,
                transform3d:        isTransform3dSupport
            }
        };
    })();

    scope.Throtting = function(data) {
        scope._throtting = data;

        //TL._timer = setInterval(function() { scope.Service.ping(TL._throtting.slug); }, 60*1000);
        $('body').on('ping', 'a,area', function() {
            scope.Service.ping(scope._throtting.slug, function() {
                window.location.reload();
            });
        });

        /**
        setTimeout(function() {
            alert("bye bye");
        }, (data.inactive_time - data.current_time - 60) * 1000); // send alert when left 60 secounds for inactive
        /**
        TL.timer = setInterval(function() {
            TL._throtting.time_left--;
            var mind = TL._throtting.time_left % (60 * 60), minutes = Math.floor(mind / 60), 
                secd = mind % 60, seconds = Math.ceil(secd), el = $("#event_remaining_time");
            if (minutes < 10) minutes = '0' + minutes;
            if (seconds < 10) seconds = '0' + seconds;
            el.find('span').html(minutes + ":" + seconds);
            el.addClass('active');
            if (TL._throtting.time_left <= 0) { 
                clearTimeout(TL.timer);
            }
        },1000);
        **/
    };

    var tabs = (function(){
        var $tabs = $("[data-tab]").tabs({selected:0, activate: function( event, ui ) { scope.loadImg(); }});

        $('a[href^="#"][data-tab-selector][data-scroll]:not(.disabled)').bind('click', function(e){
            var id = $(this).attr('href');
            $tabs.tabs( "select", id);
            if (scope.environment.getSreenSize().small) {
                $.scrollTo(id, 500 );
            }
            scope.loadImg();
            return false;
        });

        var activeTab = function(id) {
            $tabs.tabs( "select", id);
        }

        return {
            activeTab: activeTab
        }
    })();

    var getRootElement = function() { return $rootElement; };

    var getTouchPoint = function(e) {
        var originalEvent   = e.originalEvent;
        var coordinates     = originalEvent.touches && originalEvent.touches[0] || 
                              originalEvent.changedTouches && originalEvent.changedTouches[0] ||
                              originalEvent;
        return {x: coordinates.pageX, y: coordinates.pageY};
    };

    var cancelEvent = function(e){
        if (!e) e = window.event;
        if (e.preventDefault) e.preventDefault(); // move events in these elements must allways be ignored
        if (e.stopPropagation) e.stopPropagation();
        e.cancelBubble = true;
        return e.returnValue = false;
    };

    var preventGhost = (function(){
        var points = [], threshold = 25;

        var add = function(point) {
            points.push(point);
            setTimeout(function() { points.pop(); }, 500);
        };

        var has = function(point) {
            for(var idx in points) {
                if ((Math.abs(points[idx].x - point.x) <= threshold) &&
                    (Math.abs(points[idx].y - point.y) <= threshold))
                    return true;
            }
            return false;
        };

        return {addPoint: add, hasPoint: has}
    })();

    var scroll = function (element) {
        this.element = $(element);

        if (isNativeScrollSupport || !environment.getType().touch) {
            this.type = 'native';
            //this.element.css({'overflow': 'scroll', '-webkit-overflow-scrolling': 'touch'});
            return;
        }

        this.inner_container = this.element.children();

        // initialize of props
        this.panXmax = 0;
        this.panYmax = 0;
        this.dty = 0; 
        this.dtx = 0; 
        this.firstTouchPoint = undefined;
        this.lastTouchPoint = undefined;

        this.drawTransformation();
        this.bind();
    };

    scroll.prototype.bind = function() {
        // bind events
        if (isTouchSupport) {
            //console.log("scroll with touch events");
            this.type = 'touch';
            this.element.bind({
                'touchstart.scrollView':    this.start.bind(this),
                'touchmove.scrollView':     this.move.bind(this),
                'touchend.scrollView':      this.end.bind(this)
            });
        } else { // fallback to mouse
            //console.log("emulate touch event with mouse");
            this.type = 'mouse';
            this.element.bind({
                'mousedown.scrollView':     this.start.bind(this),
                'mousemove.scrollView':     this.move.bind(this),
                'mouseup.scrollView':       this.end.bind(this)
            });
        }

        this.element.bind('mousewheel.scrollView', this.wheel.bind(this));
    };

    scroll.prototype.unbind = function() {
        switch(this.type) {
            case 'native':
                break;

            case 'touch':
                //console.log("unload events");
                this.element.unbind({
                    'touchstart.scrollView':    this.start.bind(this),
                    'touchmove.scrollView':     this.move.bind(this),
                    'touchend.scrollView':      this.end.bind(this)
                });
                break;

            case 'mouse':
                //console.log("unload mouse events");
                this.element.unbind({
                    'mousedown.scrollView':     this.start.bind(this),
                    'mousemove.scrollView':     this.move.bind(this),
                    'mouseup.scrollView':       this.end.bind(this)
                });
                break;

        }
        this.element.unbind('mousewheel.scrollView', this.wheel.bind(this));
    };

    scroll.prototype.callcPan = function() {
        if (this.panXmax == 0 && this.panYmax == 0) {
            // set this.inner_container dimentions
            this.inner_container.width(this.inner_container.children().get(0).clientWidth);
            this.inner_container.height(this.inner_container.children().get(0).clientHeight);

            // calc max pan allow
            this.panXmax = Math.round(this.element.width() - this.inner_container.outerWidth(), 0);
            this.panYmax = Math.round(this.element.height() - this.inner_container.outerHeight(), 0);
            if (this.panYmax > 0) this.panYmax = 0;
            if (this.panXmax > 0) this.panXmax = 0;
        }
    };

    scroll.prototype.drawTransformation = function() {
        if (this.dtx < this.panXmax) this.dtx = this.panXmax;
        else if (this.dtx > 0) this.dtx = 0;
        if (this.dty < this.panYmax) this.dty = this.panYmax;
        else if (this.dty > 0) this.dty = 0;

        var panTransformation = is3dSupport 
                                    ? 'translate3d('+this.dtx+'px,'+this.dty+'px,0)' 
                                    : 'translate(' + this.dtx + 'px,'+this.dty+'px)';
        this.inner_container.css('-webkit-transform', panTransformation);
    };

    scroll.prototype.preventGhostClick = function(e) {
        var point = getTouchPoint(e);
        if (preventGhost.hasPoint(point)) {
            cancelEvent(e);
        }
    };

    scroll.prototype.wheel = function (e) {
        cancelEvent(e);
        this.callcPan();
        this.dty += (e.originalEvent.wheelDeltaY * -1);
        this.dtx += (e.originalEvent.wheelDeltaX * -1);
        this.drawTransformation();
    }

    scroll.prototype.start = function (e) { 
        this.callcPan();
        this.firstTouchPoint = getTouchPoint(e);
        this.lastTouchPoint = this.firstTouchPoint;
    };

    scroll.prototype.move = function (e) {
        if (typeof this.lastTouchPoint === 'undefined') return;
        cancelEvent(e);

        var point = getTouchPoint(e);
        this.dtx += point.x - this.lastTouchPoint.x;
        this.dty += point.y - this.lastTouchPoint.y;
        this.drawTransformation();
        this.lastTouchPoint = point;
    };

    scroll.prototype.end = function(e) {
		if (typeof this.lastTouchPoint === 'undefined') return;
        if (Math.abs(this.lastTouchPoint.x - this.firstTouchPoint.x) > 10 ||
            Math.abs(this.lastTouchPoint.y - this.firstTouchPoint.y) > 10) {
            TL.preventGhost.addPoint(this.lastTouchPoint);
        }
        this.lastTouchPoint = undefined;
    };

    scope.scrollView        = scroll;
    scope.tabs              = tabs;
    scope.preventGhost      = preventGhost;
    scope.cancelEvent       = cancelEvent;
    scope.environment       = environment;

    scope.getTouchPoint     = getTouchPoint;
    scope.getRootElement    = getRootElement;

})(window.TL);

