    dictionary.getMessage = function (key, replaceObj, language) {
        var message;
        if (typeof language === 'undefined') language = this['defaultLanguage'];
        if (typeof this[language] === 'object' && typeof this[language][key] !== 'undefined') {
            message = this[language][key];
        } else if (typeof this[this['defaultLanguage']] === 'object' && typeof this[this['defaultLanguage']][key] !== 'undefined') {
            message = this[this['defaultLanguage']][key];
        } else {
            message = key;
        }

        if (typeof replaceObj === 'object') {
            for (replaceKey in replaceObj) {
                message = message.replace ('%' + replaceKey + '%', replaceObj[replaceKey]);
            }
        }
        return message;
    };

    dictionary.setDefaultLanguage = function (language) {
        this['defaultLanguage'] = language;
    };

