/** 
 Common GUI 
**/
$(document).ready(function() {

    //$('a[href="#login"]')
    $('#login_link').bind('click', function(e){
        TL.cancelEvent(e);
        $("#menu,#search,#remaining_time,#locale").removeClass('active');
        $("#login").toggleClass('active');
    });

    $('#menu_link').bind('click', function(e){
        TL.cancelEvent(e);
        $("#login,#search,#remaining_time,#locale").removeClass('active');
        $("#menu").toggleClass('active');
    });

    $('#locale_link').bind('click', function(e){
        TL.cancelEvent(e);
        $("#login,#search,#remaining_time,#menu").removeClass('active');
        $("#locale").toggleClass('active');
    });

    $('#pesquisa_link').bind('click', function(e){
        TL.cancelEvent(e);
        $("#login,#menu,#remaining_time,#locale").removeClass('active');
        $("#search").toggleClass('active');
    });

    $('form.search_form a.advanced_search_toggle').bind('click', function(e){
        TL.cancelEvent(e);
        TL.getRootElement().children().toggleClass('advanced_search');
    });

    $('nav a[href="#grid_mode"]').bind('click', function(e){
        TL.cancelEvent(e);
        var $this = $(this);
        $this.siblings().removeClass('selected');
        $this.addClass('selected');
        $this.parent().parent().parent().find('.events_list').addClass('grid');
    });

    $('nav a[href="#list_mode"]').bind('click', function(e){
        TL.cancelEvent(e);
        var $this = $(this);
        $this.siblings().removeClass('selected');
        $this.addClass('selected');
        $this.parent().parent().parent().find('.events_list').removeClass('grid');
    });

    $('.button.disabled').bind('click', function(e){
        TL.cancelEvent(e);
    });

    if ($.isFunction($.cookiesDirective) && !TL.environment.isIframe()) {
        $.cookiesDirective({
            privacyPolicyUri: '/pagina/privacidade',
            duration: 0,
            position: 'bottom',
            message: TL.dictionary.getMessage('cookies_message'),
            privacyPolicyText: TL.dictionary.getMessage('privacy_policy_text'),
            impliedsubmitText: TL.dictionary.getMessage('implied_submit_text'),
            backgroundColor: '#89A135',
            backgroundOpacity: '95',
            linkColor: '#ffffff'
        });
    }
});

(function(scope){
    scope.cart_remain = function(){
        $remaining_time = $("#remaining_time");
        if ($remaining_time.length != 0) {
            clearTimeout(scope.cartIntervalNotification);
            scope.cartIntervalNotification = setInterval(function(){
                var timeLeft = $remaining_time.attr('data-time-left');
                timeLeft--; // left 1 secound
                $remaining_time.attr('data-time-left', timeLeft);

                if (timeLeft < 300 || $remaining_time.hasClass('active')) {
                    $remaining_time.addClass('active');
                    var mind = timeLeft % (60 * 60), minutes = Math.floor(mind / 60), 
                        secd = mind % 60, seconds = Math.ceil(secd);
                    if (minutes < 10) minutes = '0' + minutes;
                    if (seconds < 10) seconds = '0' + seconds;
                    $remaining_time.find('span').html(minutes + ":" + seconds);
                }
                if (timeLeft <= 0) { 
                    clearTimeout(scope.cartIntervalNotification);
                    $remaining_time.html("<p>" + scope.TL.dictionary.getMessage('cart_change') + "</p>");
                }
            }, 1000);
        }
    }
})(window);

(function(scope){
    var threshold = 500;
    var forceLoad = false;// scope.environment.getScreenSize().large && scope.environment.getType().pointer;
    scope.loadImg = function(){
        $('img[data-src-original]:not([data-loaded="true"])').each(function(i, el) {
            var t = $(el);
            var y = t.offset().top;
            var h = t.height();
            var wy = window.pageYOffset;
            var wh = $(window).height();
            if (y + h >= wy && y <= wy + wh + threshold || forceLoad) {
                t.css('visibility', 'inherit');
                if (t.is(":not(:visible)")) return;
                var src = t.attr('data-src-original');
                var width = Math.round(t.width(),0);

                // t.attr('src', src + "&W=" + (width*2));
                const url = new URL(src);
                url.searchParams.append('W', (width*2));
                t.attr('src', url.toString());
                t.attr('data-loaded', 'true');
            }
        });
        if (forceLoad) clearTimeout(interval);
    }
    var interval = setInterval(scope.loadImg, 1000);
    $(window).bind('unload', function(){
        clearTimeout(interval);
    });
})(window.TL);

// search form
(function(scope){
	var storage = window.sessionStorage, storageKey = "venuesList";

	var getSelectedDistrict = function () {
		var districtId = $('#search_form select[name="district"] option:selected').val();
		return districtId;
	};

	var getVenuesList = function(districtId) {
		var venuesList;
		try {
			if (!!storage) {
				venuesList = storage.getItem(storageKey);
				if (!venuesList) {
					venuesList = scope.ServiceProxy.call('GetCatalogVenues', {});
					storage.setItem(storageKey, JSON.stringify(venuesList));
				} else {
					try { venuesList = JSON.parse(venuesList); }
					catch (e) { venuesList = eval(venuesList); }
				}
				if (districtId != "") {
					venuesList = venuesList.filter(function(el) { return (el.districtId == this.district)}, {district: districtId});
				}
				return venuesList;
			} else {
				throw "no storage support";
			}
		} catch (e) {
			try { if (!!storage) { storage.clear() } } catch (e) {};
			return scope.ServiceProxy.call('GetCatalogVenues', {districtId: districtId});
		}
	}

	var renderVenueSelectFilter = function() {
		var $venueSelect 	= $('#search_form select[name="venue"]'), 
			districtId 		= getSelectedDistrict(),
			venuesList 		= getVenuesList(districtId);

		$venueSelect.children().remove();
		$venueSelect.append($("<option></option>").text('Todas'));
		venuesList.forEach(function(el) {
			$venueSelect.append($("<option></option>").attr('value', el.id).text(el.name));
		});
	}

	$(document).ready(function(){
		//renderVenueSelectFilter();
		$('#search_form select[name="district"]').bind('change', renderVenueSelectFilter);

		$('#search_form input[type="text"][data-element="date"]').each(function(){
			//if (this.type !== "date") {
				$(this).datepicker().datepicker("option" , "dateFormat" , "yy-mm-dd" );
			//}
		});
	});

	scope.Search = {
		renderVenueSelectFilter: 	renderVenueSelectFilter,
		getVenuesList: 				getVenuesList,
		getSelectedDistrict: 		getSelectedDistrict
	};
})(window.TL);(function (scope){

	var ServiceProxy = (function(){
		var service_interface = {},
			service_endpoint = "/ajaxHandler.php";

		service_interface.call = function(method, parameters, successCallback, errorCallback) {
			if (typeof service_endpoint === 'undefined') throw "no endpoint defined"
			var result;
			var async = typeof successCallback === 'function';
			if (!async) successCallback = function(data){result=data;};

			var processServiceResponse = function(result) {
				// it's not our ajax protocol
				try {
					if (typeof result._type == 'undefined') { 
						successCallback.apply(null, [result]); 
					} 
					else if (result._type == 'Exception') {
						if (typeof result.data == 'undefined' || typeof result.data.message !== 'string') {
							throw scope.dictionary.getMessage('unknown_error');
						} else {
							throw result.data.message;
						}
					} 
					else if (result._type == 'Result') {
						successCallback.apply(null, [result.data]);
					} 
					else {
						throw scope.dictionary.getMessage('unknown_message');
					}
				} catch (e) {
					if (typeof errorCallback === 'function') {
						errorCallback.apply(null, [e]);
					} else {
						throw e; // let exception flow
					}
				}
			};
			if (typeof errorCallback !== 'function') {
				errorCallbackAjax = function(xmlhttprequest, textstatus, message) { 
					alert(scope.dictionary.getMessage('error', {errormessage: message}));
					throw textstatus;
				}
			}  else {
				errorCallbackAjax = function(xmlhttprequest, textstatus, message) { 
					errorCallback.apply(null, [message]);
				}
			}

			var xhr = $.ajax({
				type: "POST",
				async: async,
				cache: false,
				url: service_endpoint + "?method="+method,
				data: parameters,
				timeout:60000,
				success: processServiceResponse,
				error: errorCallbackAjax,
				dataType: 'json'
			});
			
			return result;
		};

		service_interface.setEndpoint = function(endpoint) {
			service_endpoint = endpoint;
		};

		return service_interface;
	})();

	var Service = (function(){
		var interface_public = {}, reservedSeats = [], dataSession;

		interface_public.getSession = function() {
			if (typeof dataSession == 'undefined') {
				dataSession = (function(){
					var jsonData = scope.getJsonData('session-id');
					
					var get = function() {
						return jsonData;
					};

					var toString = function() {
						return jsonData.event_id + "_" + jsonData.venue_id + "_" +jsonData.datetime;
					};

					return {
						get: get,
						toString: toString
					};
				})();
			}
			return dataSession;
		};

		interface_public.getCart = function(successClb, errorClb) {
			return ServiceProxy.call('GetCart', {}, successClb, errorClb);
		};

		interface_public.getZoneById = function(id) {
			var data = $("#zone_"+id).attr('data-zone-info'), result;
			try { result = jQuery.parseJSON(data); }
			catch (e) { result = eval(data); }
			return result;
		};

		interface_public.getNumberOfSeatWithOutZone = function(zoneId, onlyPreReserved) {
			if (typeof onlyPreReserved !== 'boolean') onlyPreReserved = false;
			var numberSeats = 0;
			for (var _zoneId in reservedSeats) {
				if (zoneId == _zoneId) continue;
				var zoneData = interface_public.getZoneById(_zoneId), multi = 1;
				if (zoneData && zoneData.box && zoneData.box.number_seats > 0) {
					multi = zoneData.box.number_seats;
				}
				if (!onlyPreReserved) {
					numberSeats += reservedSeats[_zoneId].length * multi;
				} else {
					for (var idx in reservedSeats[_zoneId]) {
						var seat = reservedSeats[_zoneId][idx];
						if (seat.preReserved) {
							numberSeats += multi;
						}
					}
				}
			}
			return numberSeats;
		}

		interface_public.setEnvoriment = function(userInterface, mediaSize) {
			return ServiceProxy.call('setEnvoriment', {userInterface: userInterface, mediaSize: mediaSize}, function(){}, function(){});
		};

		interface_public.setCampaign = function(campaign, term) {
			return ServiceProxy.call('setCampaign', {campaign: campaign, term: term}, function(){}, function(){});
		};

		interface_public.ping = function(slug, errorClb) {
			return ServiceProxy.call('ping', {slug: slug}, function(){}, errorClb);
		};

		interface_public.getCategories = function(successClb, errorClb) {
			return ServiceProxy.call('GetCatalogCategories', undefined, successClb, errorClb);
		};

		interface_public.getZoneMapData = function(zoneId, sessionId, successClb, errorClb) {
			var arguments = {zoneId: zoneId, sessionId: sessionId};
			return ServiceProxy.call('GetZoneMapById', arguments, successClb, errorClb);
		};

		interface_public.getZoneReservedTickets = function(sessionId, zoneId, cartPackId, successClb, errorClb) {
			var arguments = {sessionId: sessionId, zoneId: zoneId, cartPackId: cartPackId};
			var successCbk = function(data) {
				reservedSeats = data; // use this for getNumberOfSeatWithOutZone
				successClb.apply(null, [data]);
			}
			return ServiceProxy.call('GetSeatsInCartGrouped', arguments, successCbk, errorClb);
		};

		// use this for getNumberOfSeatWithOutZone
		interface_public.setReservedSeats = function(_reservedSeats) {
			reservedSeats = _reservedSeats;
		}

		interface_public.storeSeat = function(seat, successClb, errorClb) {
			return ServiceProxy.call('StoreSeatInCart', seat, successClb, errorClb);
		};

		interface_public.removeSeat = function(seat, successClb, errorClb) {
			return ServiceProxy.call('RemoveSeatInCart', seat, successClb, errorClb);
		};

		interface_public.addCartPackToCart = function (eventPackId, selectedEventIds, numberOfTickets, successClb, errorClb) {
			return ServiceProxy.call('AddPackToCart', {'eventPackId': eventPackId, 'options': {'selectedEventIds': selectedEventIds, 'numberOfTickets': numberOfTickets}}, successClb, errorClb);
		};

		interface_public.removePackFromCart = function (cartPackId, successClb, errorClb) {
			return ServiceProxy.call('RemovePackFromCart', {'cartPackId': cartPackId}, successClb, errorClb);
		};

		interface_public.getCartPackForEvent = function (eventPackId, cleanEmpty, successClb, errorClb) {
			return ServiceProxy.call('GetFreeCartPackForEvent', {'eventPackId': eventPackId, 'cleanEmpty': cleanEmpty ? 1 : 0}, successClb, errorClb);
		};

		interface_public.deleteSeat = function(seatId, zoneId, sessionId, cartPackId, cartPackPairId, successClb, errorClb) {
			return ServiceProxy.call('DeleteSeatInCart', {'seatId': seatId, 'zoneId': zoneId, 'sessionId': sessionId, 'cartPackId': cartPackId, 'cartPackPairId': cartPackPairId}, successClb, errorClb);
		};

		interface_public.applyDiscount = function(seatId, zoneId, sessionId, discountId, successClb, errorClb) {
			var arguments = {'seatId': seatId, 'zoneId': zoneId, 'sessionId': sessionId, 'discountId': discountId};
			return ServiceProxy.call('ApplyDiscount', arguments, successClb, errorClb);
		};

		interface_public.applyCampaign = function(code, successClb, errorClb) {
			var arguments = {code: code};
			return ServiceProxy.call('ApplyCampaign', arguments, successClb, errorClb);
		};

		interface_public.removeCampaign = function(code, successClb, errorClb) {
			var arguments = {code: code};
			return ServiceProxy.call('RemoveCampaign', arguments, successClb, errorClb);
		};

		interface_public.applyDeliveryType = function(deliveryType, successClb, errorClb) {
			var arguments = {deliveryType: deliveryType};
			return ServiceProxy.call('ApplyDeliveryType', arguments, successClb, errorClb);			
		};

		interface_public.applySecure = function(active, offerId, successClb, errorClb) {
			var arguments = {'active': active, 'offerId': offerId};
			return ServiceProxy.call('ApplySecure', arguments, successClb, errorClb);
		};
		
		return interface_public;
	})();

	// export service
	scope.Service = Service;
	scope.ServiceProxy = ServiceProxy;
})(window.TL);	/**
	 * Execute callback only after all jobs done
	 */
	var Async = (function() {
		var Async = function (cb, fail, timeout) {
			this.started = 0;
			this.completed = 0;
			this.cb = cb;
			this.fail = fail;
			this.errors = [];
		};

		Async.prototype.start = function(fn) {
			++this.started;
			try {
				fn.apply(null, []);
			} catch (e) {
				this.errors.push(e);
			}
		};

		Async.prototype.end = function() {
			++this.completed;
			if (this.completed == this.started) {
				clearTimeout(this.timeout); // clear timeout jobs have finished
				if (this.errors.length == 0) {
					this.cb.apply(null, []);
				} else {
					this.fail.apply(null, [this.errors[0], this.errors]);
				}
			}
		}; 

		Async.prototype.batchEnd = function(timeout) {
			if (this.started == 0) {
				// no jobs submitted
				this.cb.apply(null, []);
				return;
			}

			if (typeof timeout == undefined) timeout = 2000; // 2 segundos
			this.timeout = setTimeout((function(){
				if (this.obj.started == this.obj.completed) { 
					// no jobs submited/started or jobs have done but not tigger for some reason
					this.obj.cb.apply(null, []);
				} else {
					this.obj.fail.apply(null, ['timeout']);
				}
			}).bind({obj: this}), timeout);
		};

		return Async;
	})();